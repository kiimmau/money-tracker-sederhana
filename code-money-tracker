<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catatan Keuangan Pribadi</title>
    <!-- Library XLSX untuk export Excel -->
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js">
    </script>
    <style>
        /* ========== RESET & GLOBAL ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: #f0f4f8;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            max-width: 1000px;
            width: 100%;
            background: white;
            border-radius: 24px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        }

        h1 {
            font-size: 28px;
            color: #1e293b;
            margin-bottom: 25px;
            text-align: center;
            font-weight: 700;
        }
        h1 span {
            font-size: 30px;
        }

        /* ========== KARTU SALDO ========== */
        .summary {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 25px;
        }

        .card {
            background: #f8fafc;
            padding: 16px;
            border-radius: 16px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
            border: 1px solid #e9eef3;
        }

        .card .label {
            font-size: 14px;
            color: #64748b;
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        .card .value {
            font-size: 26px;
            font-weight: 700;
            margin-top: 6px;
        }

        .card.balance .value {
            color: #0f172a;
        }
        .card.income .value {
            color: #16a34a;
        }
        .card.expense .value {
            color: #dc2626;
        }

        /* ========== FORM TAMBAH ========== */
        .add-form {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 20px;
            background: #f8fafc;
            padding: 18px;
            border-radius: 16px;
            border: 1px solid #e9eef3;
        }

        .add-form input,
        .add-form select {
            flex: 1 1 130px;
            padding: 12px 16px;
            border: 1px solid #d1d9e6;
            border-radius: 12px;
            font-size: 15px;
            background: white;
            transition: 0.2s;
        }

        .add-form input:focus,
        .add-form select:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
        }

        .add-form button {
            flex: 1 1 100px;
            padding: 12px 20px;
            background: #3b82f6;
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }

        .add-form button:hover {
            background: #2563eb;
        }

        /* ========== RINGKASAN PER BULAN ========== */
        .monthly-section {
            background: #f1f5f9;
            padding: 16px 18px;
            border-radius: 16px;
            margin-bottom: 20px;
            border: 1px solid #e2e8f0;
        }

        .monthly-section h3 {
            font-size: 16px;
            color: #334155;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .monthly-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 12px;
        }

        .month-item {
            background: white;
            padding: 12px 14px;
            border-radius: 12px;
            border: 1px solid #dce2ea;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.02);
        }

        .month-item .month-label {
            font-weight: 700;
            color: #0f172a;
            font-size: 15px;
            margin-bottom: 6px;
        }

        .month-item .month-detail {
            font-size: 13px;
            color: #475569;
            line-height: 1.6;
        }
        .month-item .month-detail .in {
            color: #16a34a;
            font-weight: 600;
        }
        .month-item .month-detail .out {
            color: #dc2626;
            font-weight: 600;
        }
        .month-item .month-detail .bal {
            font-weight: 700;
            color: #0f172a;
        }

        .no-month-data {
            color: #94a3b8;
            font-size: 14px;
            padding: 8px 0;
        }

        /* ========== FILTER & EXPORT ========== */
        .toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 20px;
            align-items: center;
            justify-content: space-between;
        }

        .filters {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .filters button {
            padding: 8px 18px;
            border: 1px solid #d1d9e6;
            background: white;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            color: #334155;
        }

        .filters button:hover {
            background: #eef2f6;
        }

        .filters button.active {
            background: #1e293b;
            color: white;
            border-color: #1e293b;
        }

        .btn-export {
            padding: 8px 24px;
            background: #059669;
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-export:hover {
            background: #047857;
        }

        /* ========== DAFTAR TRANSAKSI (TABEL) ========== */
        .list-container {
            border-radius: 16px;
            border: 1px solid #e9eef3;
            overflow-x: auto;
            background: #ffffff;
        }

        .list-header {
            display: grid;
            grid-template-columns: 40px 110px 1fr 1fr 1fr 45px;
            padding: 14px 16px;
            background: #f1f5f9;
            font-weight: 600;
            font-size: 13px;
            color: #475569;
            border-bottom: 1px solid #e2e8f0;
            min-width: 600px;
        }

        #transaction-list {
            list-style: none;
            padding: 0;
            margin: 0;
            max-height: 400px;
            overflow-y: auto;
        }

        .transaction-item {
            display: grid;
            grid-template-columns: 40px 110px 1fr 1fr 1fr 45px;
            align-items: center;
            padding: 12px 16px;
            border-bottom: 1px solid #f1f5f9;
            transition: background 0.15s;
            min-width: 600px;
        }

        .transaction-item:hover {
            background: #fafcff;
        }

        .transaction-item .col-no {
            color: #94a3b8;
            font-size: 13px;
            text-align: center;
        }
        .transaction-item .col-date {
            font-size: 13px;
            color: #475569;
        }
        .transaction-item .col-desc {
            font-weight: 500;
            color: #0f172a;
            padding-right: 10px;
        }
        .transaction-item .col-income {
            color: #16a34a;
            font-weight: 600;
            text-align: right;
            padding-right: 10px;
        }
        .transaction-item .col-expense {
            color: #dc2626;
            font-weight: 600;
            text-align: right;
            padding-right: 10px;
        }

        .transaction-item .delete-btn {
            background: none;
            border: none;
            color: #94a3b8;
            font-size: 20px;
            cursor: pointer;
            transition: color 0.2s;
            text-align: center;
            line-height: 1;
        }

        .transaction-item .delete-btn:hover {
            color: #dc2626;
        }

        .empty-message {
            text-align: center;
            padding: 40px 20px;
            color: #94a3b8;
            font-size: 16px;
            grid-column: 1 / -1;
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 700px) {
            .container {
                padding: 16px;
            }

            .summary {
                grid-template-columns: 1fr 1fr;
            }
            .card.balance {
                grid-column: span 2;
            }

            .add-form input,
            .add-form select {
                flex: 1 1 100%;
            }
            .add-form button {
                flex: 1 1 100%;
            }

            .toolbar {
                flex-direction: column;
                align-items: stretch;
            }
            .filters {
                justify-content: center;
            }
            .btn-export {
                justify-content: center;
            }

            .list-header,
            .transaction-item {
                grid-template-columns: 30px 90px 1fr 0.8fr 0.8fr 35px;
                font-size: 12px;
                padding: 10px 12px;
                min-width: 500px;
            }
            .transaction-item .delete-btn {
                font-size: 18px;
            }
            .monthly-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 450px) {
            .summary {
                grid-template-columns: 1fr;
            }
            .card.balance {
                grid-column: span 1;
            }
            .monthly-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <h1><span>💰</span> Catatan Keuangan</h1>

        <!-- KARTU RINGKASAN -->
        <div class="summary">
            <div class="card balance">
                <div class="label">💳 Total Saldo</div>
                <div class="value" id="balance">Rp 0</div>
            </div>
            <div class="card income">
                <div class="label">📈 Pemasukan</div>
                <div class="value" id="total-income">Rp 0</div>
            </div>
            <div class="card expense">
                <div class="label">📉 Pengeluaran</div>
                <div class="value" id="total-expense">Rp 0</div>
            </div>
        </div>

        <!-- FORM TAMBAH -->
        <div class="add-form">
            <input type="date" id="date-input" />
            <input type="text" id="desc-input" placeholder="Keterangan" />
            <input type="number" id="amount-input" placeholder="Jumlah (Rp)" min="0" />
            <select id="type-input">
                <option value="income">📈 Pemasukan</option>
                <option value="expense">📉 Pengeluaran</option>
            </select>
            <button onclick="addTransaction()">➕ Tambah</button>
        </div>

        <!-- RINGKASAN PER BULAN -->
        <div class="monthly-section">
            <h3>📅 Ringkasan per Bulan</h3>
            <div class="monthly-grid" id="monthly-summary">
                <!-- Diisi oleh JavaScript -->
            </div>
        </div>

        <!-- TOOLBAR: FILTER + EXPORT -->
        <div class="toolbar">
            <div class="filters">
                <button class="active" data-filter="all" onclick="setFilter('all')">Semua</button>
                <button data-filter="income" onclick="setFilter('income')">📈 Pemasukan</button>
                <button data-filter="expense" onclick="setFilter('expense')">📉 Pengeluaran</button>
            </div>
            <button class="btn-export" onclick="exportToExcel()">📊 Ekspor ke Excel</button>
        </div>

        <!-- DAFTAR TRANSAKSI -->
        <div class="list-container">
            <div class="list-header">
                <span>#</span>
                <span>Tanggal</span>
                <span>Keterangan</span>
                <span style="text-align:right;">Pemasukan</span>
                <span style="text-align:right;">Pengeluaran</span>
                <span style="text-align:center;">Hapus</span>
            </div>
            <ul id="transaction-list">
                <!-- Akan diisi oleh JavaScript -->
            </ul>
        </div>
    </div>

    <script>
        // ==========================================================
        //  DATA & STATE
        // ==========================================================
        let transactions = [];
        let currentFilter = 'all'; // 'all', 'income', 'expense'

        // Elemen DOM
        const listEl = document.getElementById('transaction-list');
        const balanceEl = document.getElementById('balance');
        const totalIncomeEl = document.getElementById('total-income');
        const totalExpenseEl = document.getElementById('total-expense');
        const monthlySummaryEl = document.getElementById('monthly-summary');

        const dateInput = document.getElementById('date-input');
        const descInput = document.getElementById('desc-input');
        const amountInput = document.getElementById('amount-input');
        const typeInput = document.getElementById('type-input');

        // Set tanggal default = hari ini
        function getToday() {
            return new Date().toISOString().split('T')[0];
        }
        dateInput.value = getToday();

        // ==========================================================
        //  LOAD & SAVE ke LocalStorage
        // ==========================================================
        function loadFromStorage() {
            const stored = localStorage.getItem('keuangan_data');
            if (stored) {
                try {
                    transactions = JSON.parse(stored);
                    // Jika data lama belum punya properti 'date', beri tanggal default
                    let needSave = false;
                    transactions.forEach(t => {
                        if (!t.date) {
                            t.date = '2026-06-01'; // fallback
                            needSave = true;
                        }
                    });
                    if (needSave) saveToStorage();
                } catch {
                    transactions = [];
                }
            } else {
                // Data default dengan tanggal
                transactions = [
                    { id: 1, desc: 'Gaji Bulanan', amount: 5000000, type: 'income', date: '2026-06-25' },
                    { id: 2, desc: 'Makan Siang', amount: 35000, type: 'expense', date: '2026-06-26' },
                    { id: 3, desc: 'Beli Pulsa', amount: 50000, type: 'expense', date: '2026-07-01' },
                    { id: 4, desc: 'Proyek Freelance', amount: 1200000, type: 'income', date: '2026-07-05' },
                ];
                saveToStorage();
            }
        }

        function saveToStorage() {
            localStorage.setItem('keuangan_data', JSON.stringify(transactions));
        }

        // ==========================================================
        //  RENDER UTAMA
        // ==========================================================
        function render() {
            // 1. Hitung total keseluruhan
            let totalIncome = 0;
            let totalExpense = 0;
            transactions.forEach(t => {
                if (t.type === 'income') totalIncome += t.amount;
                else totalExpense += t.amount;
            });
            const balance = totalIncome - totalExpense;

            // 2. Update kartu
            balanceEl.textContent = `Rp ${balance.toLocaleString('id-ID')}`;
            totalIncomeEl.textContent = `Rp ${totalIncome.toLocaleString('id-ID')}`;
            totalExpenseEl.textContent = `Rp ${totalExpense.toLocaleString('id-ID')}`;

            // 3. Render ringkasan per bulan
            renderMonthlySummary();

            // 4. Filter data untuk daftar
            let filtered = transactions;
            if (currentFilter === 'income') {
                filtered = transactions.filter(t => t.type === 'income');
            } else if (currentFilter === 'expense') {
                filtered = transactions.filter(t => t.type === 'expense');
            }

            // 5. Render daftar transaksi (urut dari yang terbaru)
            const sorted = [...filtered].sort((a, b) => b.id - a.id);

            if (sorted.length === 0) {
                listEl.innerHTML = `
                    <li class="transaction-item" style="display:block; text-align:center; padding:40px; color:#94a3b8;">
                        📭 Belum ada transaksi. Yuk tambahkan!
                    </li>
                `;
                return;
            }

            let html = '';
            sorted.forEach((t, index) => {
                const isIncome = t.type === 'income';
                const incomeDisplay = isIncome ? `Rp ${t.amount.toLocaleString('id-ID')}` : '';
                const expenseDisplay = !isIncome ? `Rp ${t.amount.toLocaleString('id-ID')}` : '';
                // format tanggal
                const dateFormatted = t.date ? t.date.split('-').reverse().join('/') : '-';

                html += `
                    <li class="transaction-item">
                        <span class="col-no">${index + 1}</span>
                        <span class="col-date">${dateFormatted}</span>
                        <span class="col-desc">${escapeHTML(t.desc)}</span>
                        <span class="col-income">${incomeDisplay}</span>
                        <span class="col-expense">${expenseDisplay}</span>
                        <button class="delete-btn" onclick="deleteTransaction(${t.id})" title="Hapus">✕</button>
                    </li>
                `;
            });

            listEl.innerHTML = html;
        }

        // ==========================================================
        //  RINGKASAN PER BULAN
        // ==========================================================
        function renderMonthlySummary() {
            if (transactions.length === 0) {
                monthlySummaryEl.innerHTML = `<div class="no-month-data">Belum ada data untuk ditampilkan.</div>`;
                return;
            }

            const monthMap = {};

            transactions.forEach(t => {
                if (!t.date) return;
                const monthKey = t.date.substring(0, 7); // YYYY-MM
                if (!monthMap[monthKey]) {
                    monthMap[monthKey] = { income: 0, expense: 0 };
                }
                if (t.type === 'income') {
                    monthMap[monthKey].income += t.amount;
                } else {
                    monthMap[monthKey].expense += t.amount;
                }
            });

            // Urutkan bulan dari terbaru ke terlama
            const sortedMonths = Object.keys(monthMap).sort((a, b) => b.localeCompare(a));

            let html = '';
            sortedMonths.forEach(key => {
                const data = monthMap[key];
                const total = data.income - data.expense;
                const [year, month] = key.split('-');
                const monthName = new Date(year, month - 1).toLocaleString('id-ID', { month: 'long' });
                const label = `${monthName} ${year}`;

                html += `
                    <div class="month-item">
                        <div class="month-label">${label}</div>
                        <div class="month-detail">
                            <span class="in">+ Rp ${data.income.toLocaleString('id-ID')}</span> &nbsp;|&nbsp;
                            <span class="out">- Rp ${data.expense.toLocaleString('id-ID')}</span><br>
                            <span class="bal">Saldo: Rp ${total.toLocaleString('id-ID')}</span>
                        </div>
                    </div>
                `;
            });

            monthlySummaryEl.innerHTML = html;
        }

        // ==========================================================
        //  CRUD: TAMBAH & HAPUS
        // ==========================================================
        function addTransaction() {
            const date = dateInput.value;
            const desc = descInput.value.trim();
            const amount = parseFloat(amountInput.value);
            const type = typeInput.value;

            // Validasi
            if (!date) {
                alert('⚠️ Silakan pilih tanggal!');
                dateInput.focus();
                return;
            }
            if (desc === '') {
                alert('⚠️ Keterangan tidak boleh kosong!');
                descInput.focus();
                return;
            }
            if (isNaN(amount) || amount <= 0) {
                alert('⚠️ Masukkan jumlah yang valid (lebih dari 0)!');
                amountInput.focus();
                return;
            }

            const newTransaction = {
                id: Date.now(),
                date: date,
                desc: desc,
                amount: amount,
                type: type
            };

            transactions.push(newTransaction);
            saveToStorage();
            render();

            // Reset form (tanggal tetap hari ini)
            dateInput.value = getToday();
            descInput.value = '';
            amountInput.value = '';
            descInput.focus();
        }

        function deleteTransaction(id) {
            if (!confirm('Yakin ingin menghapus transaksi ini?')) return;
            transactions = transactions.filter(t => t.id !== id);
            saveToStorage();
            render();
        }

        // ==========================================================
        //  FILTER
        // ==========================================================
        function setFilter(filter) {
            currentFilter = filter;
            document.querySelectorAll('.filters button').forEach(btn => {
                btn.classList.remove('active');
                if (btn.dataset.filter === filter) {
                    btn.classList.add('active');
                }
            });
            render();
        }

        // ==========================================================
        //  EKSPOR KE EXCEL (.xlsx)
        // ==========================================================
        function exportToExcel() {
            if (transactions.length === 0) {
                alert('Belum ada data untuk diekspor!');
                return;
            }

            // Siapkan data sesuai format yang diminta: Tanggal, Keterangan, Pemasukan, Pengeluaran
            // Urutkan berdasarkan tanggal (lama ke baru) agar rapi
            const sorted = [...transactions].sort((a, b) => (a.date || '').localeCompare(b.date || ''));

            const excelData = sorted.map(t => {
                const dateFormatted = t.date ? t.date.split('-').reverse().join('/') : '-';
                return {
                    'Tanggal': dateFormatted,
                    'Keterangan': t.desc,
                    'Pemasukan': t.type === 'income' ? t.amount : 0,
                    'Pengeluaran': t.type === 'expense' ? t.amount : 0
                };
            });

            // Tambahkan baris total di bagian bawah (opsional)
            const totalIncome = transactions.filter(t => t.type === 'income').reduce((sum, t) => sum + t.amount, 0);
            const totalExpense = transactions.filter(t => t.type === 'expense').reduce((sum, t) => sum + t.amount, 0);
            excelData.push({
                'Tanggal': 'TOTAL',
                'Keterangan': '',
                'Pemasukan': totalIncome,
                'Pengeluaran': totalExpense
            });

            // Buat worksheet dan workbook
            const ws = XLSX.utils.json_to_sheet(excelData);

            // Atur lebar kolom agar pas
            ws['!cols'] = [
                { wch: 15 }, // Tanggal
                { wch: 30 }, // Keterangan
                { wch: 18 }, // Pemasukan
                { wch: 18 } // Pengeluaran
            ];

            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Keuangan');

            // Generate nama file
            const today = getToday();
            const filename = `Keuangan_${today}.xlsx`;

            // Download
            XLSX.writeFile(wb, filename);
        }

        // ==========================================================
        //  UTILITY
        // ==========================================================
        function escapeHTML(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ==========================================================
        //  ENTER KEY SUPPORT
        // ==========================================================
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                const active = document.activeElement;
                if (active === dateInput || active === descInput || active === amountInput || active === typeInput) {
                    e.preventDefault();
                    addTransaction();
                }
            }
        });

        // ==========================================================
        //  START APLIKASI
        // ==========================================================
        loadFromStorage();
        render();
    </script>
</body>
